{
  "name": "@noetaris/harness-store",
  "version": "0.2.0",
  "description": "Session store implementations for @noetaris/harness",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noetaris-lab/harness-store.git"
  },
  "homepage": "https://github.com/noetaris-lab/harness-store#readme",
  "bugs": {
    "url": "https://github.com/noetaris-lab/harness-store/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build && pnpm test",
    "publish:npm": "pnpm publish --access public --no-git-checks"
  },
  "files": [
    "dist"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@noetaris/harness": "link:../core",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
